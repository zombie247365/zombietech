{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "module": "commonjs",
    "moduleResolution": "node",
    "baseUrl": "./src",
    "paths": {
      "@zombietech/shared": ["../../packages/shared/src/index"],
      "@zombietech/database": ["../../packages/database/src/index"],
      "@zombietech/shared/*": ["../../packages/shared/src/*"],
      "@zombietech/database/*": ["../../packages/database/src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
